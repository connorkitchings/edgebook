EDGEBOOK_PROJECT_NAME=Edgebook
DATABASE_URL=postgresql://edgebook:edgebook@db:5432/edgebook
ENV=production
DEBUG=false
PORT=8000
HOST=0.0.0.0

# Security
# In production (ENV=production), SECRET_KEY is required, must differ from the
# default placeholder, and must be at least 32 characters. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=generate-a-secure-random-key-for-production-signing

# PostgreSQL Credentials
POSTGRES_USER=edgebook
POSTGRES_PASSWORD=edgebook
POSTGRES_DB=edgebook
INGESTION_MIN_PROVIDERS=3
INGESTION_PROVIDER_NAMES=
ODDS_API_KEY=
SPORTSDATAIO_API_KEY=
COLLEGE_FOOTBALL_DATA_API_KEY=
INGESTION_HTTP_TIMEOUT_SECONDS=10
INGESTION_HTTP_MAX_RETRIES=2
INGESTION_MIN_QUOTA_REMAINING=100
ODDS_API_REGIONS=us
# Comma-separated bookmaker keys retained in the daily pregame research feed.
ODDS_API_BOOKMAKERS=draftkings,fanduel,betmgm,caesars

# Alerting: POST a JSON payload to this URL when an ingestion run fails.
# Leave empty to disable webhook notifications. Delivery is best-effort.
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_TIMEOUT_SECONDS=5

# Session cookies: set to true once HTTPS is in front of the app (see
# docs/deployment.md). Leave false for the plain-HTTP interim.
SESSION_COOKIE_SECURE=false
